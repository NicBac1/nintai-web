---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/ui/Section.astro';
import BookingCTA from '@/components/booking/BookingCTA.astro';
import { siteConfig } from '@/lib/site';
import teamLunch from '@/assets/photos/team-lunch.png';

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const pillars = (await getCollection('pillars')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout
  title="Sobre Nintai"
  description="Conoce a Nintai: nuestra esencia, nuestros pilares y la mirada con la que acompañamos procesos humanos."
>
  <section class="bg-cream py-section-lg">
    <div class="container-prose grid items-center gap-12 md:grid-cols-[1fr_1.2fr] md:gap-16">
      <div class="relative mx-auto w-full max-w-sm">
        <div class="absolute -inset-6 -z-10 rounded-3xl bg-sage-tint" aria-hidden="true"></div>
        <img
          src={`${baseUrl}/logo/nintai.svg`}
          alt="Nintai · Experiencias Psicoeducativas"
          class="h-auto w-full"
        />
      </div>

      <div>
        <p class="eyebrow mb-4">Sobre Nintai</p>
        <h1 class="font-display text-display-xl text-sage-deep">
          Creemos que cuidar también transforma
        </h1>
        <p class="mt-6 text-lg text-ink/85">
          Por eso generamos espacios que integran reflexión, aprendizaje y
          herramientas prácticas para acompañar procesos humanos con sentido.
        </p>
      </div>
    </div>
  </section>

  <Section bg="cream-deep" eyebrow="Nuestra esencia" title="Lo que sostiene nuestro trabajo">
    <div class="mx-auto max-w-2xl text-ink/85">
      <p class="text-lg">
        En Nintai creemos que el bienestar emocional es la base para construir
        vínculos más conscientes, entornos más saludables y procesos de desarrollo
        verdaderamente significativos.
      </p>
      <p class="mt-5">
        Acompañamos a comunidades educativas, familias, organizaciones y a
        quienes están atravesando procesos personales de reflexión y
        transformación. Cada experiencia se diseña a la medida del contexto,
        cuidando que lo que se vive en el encuentro se pueda sostener después.
      </p>
    </div>
  </Section>

  <Section eyebrow="Cuatro pilares" title="Nuestra forma de acompañar">
    <div class="mx-auto grid max-w-4xl gap-8 md:grid-cols-2">
      {
        pillars.map((pillar) => (
          <div class="flex gap-5">
            <span class="inline-flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-full bg-sage-tint">
              <Icon name={pillar.data.icon} class="h-7 w-7 text-sage" />
            </span>
            <div>
              <h3 class="font-display text-2xl text-sage-deep">{pillar.data.name}</h3>
              <p class="mt-2 text-ink/80">{pillar.data.shortDescription}</p>
            </div>
          </div>
        ))
      }
    </div>
  </Section>

  <Section bg="cream-deep">
    <div class="grid items-center gap-12 md:grid-cols-2">
      <Image
        src={teamLunch}
        alt="Equipo Nintai compartiendo después de un encuentro"
        widths={[500, 900]}
        sizes="(min-width: 768px) 45vw, 100vw"
        class="aspect-[4/3] w-full rounded-2xl object-cover"
      />
      <div>
        <p class="eyebrow mb-3">¿Dónde nos encuentras?</p>
        <h2 class="font-display text-display-md text-sage-deep">
          {siteConfig.locations.join(' · ')}
        </h2>
        <p class="mt-5 text-ink/80">
          Trabajamos en Bogotá y Fusagasugá en modalidad presencial, y
          acompañamos procesos en cualquier parte del mundo en modalidad virtual.
        </p>
        <div class="mt-8">
          <BookingCTA label="¿Conversamos?" />
        </div>
      </div>
    </div>
  </Section>
</BaseLayout>
