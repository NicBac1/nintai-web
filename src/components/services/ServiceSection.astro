---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import BookingCTA from '@/components/booking/BookingCTA.astro';
import { audienceByKey } from '@/lib/site';
import type { CollectionEntry } from 'astro:content';

interface Props {
  service: CollectionEntry<'services'>;
  reverse?: boolean;
}

const { service, reverse = false } = Astro.props;
const { data } = service;
const audience = audienceByKey[data.audience];
const anchor = audience?.anchor ?? data.audience;
---

<section
  id={anchor}
  class="scroll-mt-24 py-section first:pt-0 last:pb-0 border-b border-cream-deep/50 last:border-b-0"
>
  <div class:list={['grid items-center gap-10 md:grid-cols-2 md:gap-16', reverse ? 'md:[&>:first-child]:order-2' : '']}>
    <Image
      src={data.image}
      alt={data.imageAlt}
      widths={[600, 1000]}
      sizes="(min-width: 768px) 45vw, 100vw"
      class="aspect-[4/3] w-full rounded-2xl object-cover"
    />

    <div>
      {
        audience && (
          <p class="eyebrow mb-3 inline-flex items-center gap-2">
            <Icon name={audience.icon} class="h-4 w-4" />
            {audience.label}
          </p>
        )
      }
      <h2 class="font-display text-display-md text-sage-deep">{data.sectionTitle}</h2>
      <p class="mt-5 text-ink/85">{data.summary}</p>

      {
        data.workBullets.length > 0 && (
          <div class="mt-6">
            <p class="text-sm font-semibold text-sage-deep">En este espacio trabajamos:</p>
            <ul class="mt-3 grid gap-2.5">
              {data.workBullets.map((bullet) => (
                <li class="flex items-start gap-3 text-ink/85">
                  <Icon name="lucide:check" class="mt-1 h-4 w-4 flex-shrink-0 text-sage" />
                  <span>{bullet}</span>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      <div class="mt-8">
        <BookingCTA audience={data.audience} label={data.ctaLabel} variant="primary" />
      </div>
    </div>
  </div>
</section>
