---
import { Icon } from 'astro-icon/components';
import SubscribeForm from '@/components/subscribe/SubscribeForm.astro';
import { siteConfig } from '@/lib/site';
import { buildWhatsappUrl } from '@/lib/whatsapp';

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const year = new Date().getFullYear();
const wa = buildWhatsappUrl();
---

<footer class="mt-section-lg border-t border-cream-deep/60 bg-cream-deep/40">
  <div class="container-prose py-section">
    <div class="grid gap-12 md:grid-cols-[1.2fr_1fr_1fr]">
      <div>
        <img
          src={`${baseUrl}/logo/nintai.svg`}
          alt={siteConfig.businessName}
          width="200"
          height="100"
          class="mb-6 h-14 w-auto"
        />
        <p class="max-w-sm font-display text-xl italic text-sage-deep">
          {siteConfig.tagline}
        </p>
        <p class="mt-4 text-sm text-muted">
          {siteConfig.locations.join(' · ')}
        </p>
      </div>

      <div>
        <h4 class="text-sm font-semibold uppercase tracking-[0.18em] text-muted">
          Conversemos
        </h4>
        <ul class="mt-5 space-y-3 text-sm">
          <li>
            <a href={wa} class="inline-flex items-center gap-2 text-ink hover:text-sage" target="_blank" rel="noopener">
              <Icon name="lucide:message-circle" class="h-4 w-4" />
              WhatsApp
            </a>
          </li>
          <li>
            <a href={`mailto:${siteConfig.email}`} class="inline-flex items-center gap-2 text-ink hover:text-sage">
              <Icon name="lucide:mail" class="h-4 w-4" />
              {siteConfig.email}
            </a>
          </li>
          <li>
            <a
              href={siteConfig.instagramUrl}
              class="inline-flex items-center gap-2 text-ink hover:text-sage"
              target="_blank"
              rel="noopener"
            >
              <Icon name="lucide:instagram" class="h-4 w-4" />
              @{siteConfig.instagramHandle}
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold uppercase tracking-[0.18em] text-muted">
          Mantente al tanto
        </h4>
        <p class="mt-3 text-sm text-muted">
          Recibe nuestras próximas experiencias en tu correo.
        </p>
        <div class="mt-5">
          <SubscribeForm compact />
        </div>
      </div>
    </div>

    <div class="mt-12 flex flex-col-reverse gap-3 border-t border-cream-deep pt-6 text-xs text-muted md:flex-row md:items-center md:justify-between">
      <p>© {year} {siteConfig.businessName} · Experiencias Psicoeducativas</p>
      <a href={`${baseUrl}/privacidad`} class="hover:text-sage">Política de privacidad</a>
    </div>
  </div>
</footer>
