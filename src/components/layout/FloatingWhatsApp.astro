---
import { Icon } from 'astro-icon/components';
import { buildWhatsappUrl } from '@/lib/whatsapp';

const wa = buildWhatsappUrl();
---

<a
  href={wa}
  target="_blank"
  rel="noopener"
  aria-label="Conversar por WhatsApp"
  class="fixed bottom-5 right-5 z-50 inline-flex h-14 w-14 items-center justify-center rounded-full bg-sage text-cream shadow-soft transition-transform duration-200 ease-out hover:-translate-y-0.5 hover:bg-sage-deep focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sage focus-visible:ring-offset-2 focus-visible:ring-offset-cream md:bottom-8 md:right-8"
>
  <Icon name="lucide:message-circle" class="h-7 w-7" />
</a>
