---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  event: CollectionEntry<'events'>;
}

const { event } = Astro.props;
const { data } = event;

const dateFmt = new Intl.DateTimeFormat('es-CO', {
  month: 'long',
  year: 'numeric',
});
const dateLabel = dateFmt.format(data.startsAt);
---

<figure class="group overflow-hidden rounded-2xl bg-cream-deep/60">
  <div class="relative overflow-hidden">
    <Image
      src={data.coverImage}
      alt={data.coverAlt}
      widths={[400, 800]}
      sizes="(min-width: 768px) 33vw, 100vw"
      class="aspect-[4/3] w-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
  </div>
  <figcaption class="p-5">
    <p class="eyebrow mb-1.5 capitalize text-muted">{dateLabel}</p>
    <h3 class="font-display text-xl text-sage-deep">{data.title}</h3>
    <p class="mt-2 text-sm text-ink/80">{data.summary}</p>
  </figcaption>
</figure>
